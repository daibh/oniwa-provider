# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: Custom OpenAI-compatible base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Server port (default: 8080)
# PORT=8080

# Optional: Default OpenAI model when no mapping matches (default: gpt-4o)
# DEFAULT_MODEL=gpt-4o

# Optional: Map Anthropic model IDs to OpenAI model IDs
# JSON format: {"claude-sonnet-4-6-20250514":"gpt-4o","claude-haiku-4-5-20251001":"gpt-4o-mini"}
# MODEL_MAPPING={"claude-sonnet-4-6-20250514":"gpt-4o","claude-haiku-4-5-20251001":"gpt-4o-mini","claude-opus-4-5-20250514":"gpt-4o"}

# Optional: Per-model API keys. Keyed by the resolved OpenAI model name.
# Models not listed here fall back to OPENAI_API_KEY.
# JSON format: {"gpt-4o":"sk-key-1","gpt-4o-mini":"sk-key-2"}
# MODEL_API_KEYS={"gpt-4o":"sk-your-gpt4o-key","gpt-4o-mini":"sk-your-mini-key"}

# Optional: Set the same value as Claude Code's ANTHROPIC_AUTH_TOKEN.
# The proxy will only accept requests with this token via Authorization: Bearer.
# If not set, any key is accepted.
# ANTHROPIC_AUTH_TOKEN=my-secret-key
