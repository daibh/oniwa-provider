# === AUTHENTICATION ===

# Admin API key for /v1/admin/* endpoints (user management, pricing, metrics)
# Required for admin operations.
# ADMIN_API_KEY=sk-admin-secret-key

# === PROVIDER CONFIGURATION ===

# Define multiple AI providers with their endpoints and format.
# Supported formats: "openai" (GPT, DeepSeek, etc.), "anthropic" (Claude)
# PROVIDERS={"openai":{"baseUrl":"https://api.openai.com/v1","apiKey":"sk-...","format":"openai"},"deepseek":{"baseUrl":"https://api.deepseek.com/v1","apiKey":"sk-...","format":"openai"}}

# Route resolved models to providers. Key = resolved model name, Value = provider id from PROVIDERS
# MODEL_ROUTING={"gpt-4o":"openai","gpt-4o-mini":"openai","deepseek-chat":"deepseek"}

# === MODEL MAPPING ===

# Map Anthropic model IDs to provider's model IDs
# MODEL_MAPPING={"claude-sonnet-4-6-20250514":"gpt-4o","claude-haiku-4-5-20251001":"gpt-4o-mini","claude-opus-4-5-20250514":"gpt-4o"}

# === PER-MODEL SETTINGS ===

# Per-model API keys (overrides provider.apiKey for specific models)
# MODEL_API_KEYS={"gpt-4o":"sk-key-1","gpt-4o-mini":"sk-key-2"}

# Per-model context window limits (default: 128000)
# MODEL_CONTEXT_LIMITS={"gpt-4o":128000,"gpt-4o-mini":128000}

# === LIMITS ===

# Maximum output tokens cap (default: 16384)
# MAX_OUTPUT_TOKENS=16384

# Maximum image size in base64 bytes. Images larger than this are replaced
# with a text placeholder to avoid exceeding context limits.
# Default: 5242880 (5MB). Set to 0 to block all images.
# MAX_IMAGE_SIZE=5242880

# === AWS (for user management + usage tracking) ===

# S3 bucket for user profiles, token hashes, and pricing config
# Required for user management features.
# S3_BUCKET=my-oniwa-provider-data

# AWS region (default: us-east-1)
# AWS_REGION=us-east-1

# CloudWatch Logs group name for usage records (default: /aws/lambda/oniwa-provider)
# CW_LOG_GROUP=/aws/lambda/oniwa-provider

# === SERVER ===

# Server port (default: 8080)
# PORT=8080
